# Iatris Environment Variables
# Copy this file to .env.local and fill in your actual keys.
# DO NOT commit .env.local to source control!

# ---------------------------------------------------------
# PHASE 1: CORE MVP
# ---------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ---------------------------------------------------------
# PHASE 2: ENHANCEMENTS
# ---------------------------------------------------------

# Anthropic Claude API (AI Symptom Triage)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Twilio (SMS Fallback)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# (Optional Alternative to Twilio) Africa's Talking
# AFRICAS_TALKING_USERNAME="your-username"
# AFRICAS_TALKING_API_KEY="your-api-key"

# ---------------------------------------------------------
# PHASE 3: SCALE
# ---------------------------------------------------------

# Python ML Model / Backend URL (Predictive Demand Mapping)
# ML_MODEL_API_URL="http://localhost:8000/api/predict"

# FHIR External API Endpoint
# NEXT_PUBLIC_FHIR_BASE_URL="your-fhir-endpoint"
